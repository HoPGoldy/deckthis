{
  "name": "deckthis",
  "version": "0.1.2",
  "description": "Write presentations as HTML files, served with a lightweight dev server",
  "keywords": [
    "presentation",
    "slides",
    "html",
    "deck",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/HoPGoldy/deckthis#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoPGoldy/deckthis"
  },
  "bugs": {
    "url": "https://github.com/HoPGoldy/deckthis/issues"
  },
  "type": "module",
  "bin": {
    "deckthis": "./dist/deckthis.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/deckthis.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "hono": "^4.4.0",
    "tsx": "^4.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}