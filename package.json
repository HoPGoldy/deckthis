{
  "name": "deckthis-workspace",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm build:core && pnpm --filter deckthis build",
    "build:core": "pnpm --filter deckthis-core build",
    "dev": "pnpm --filter deckthis dev",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter deckthis-core test",
    "test:cli": "pnpm --filter deckthis test",
    "release": "commit-and-tag-version && git push --follow-tags origin main"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.3"
  }
}